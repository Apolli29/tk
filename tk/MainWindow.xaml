<Window x:Class="tk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:tk"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBox x:Name="DistanceBox"
                 PlaceholderText="Расстояние"/>
    <TextBox x:Name="TimeBox"
             PlaceholderText="Время"/>

    <RadioButton x:Name="Meters" Content="м/с" IsChecked="True"/>
    <RadioButton x:Name="Km" Content="км/ч"/>

    <Button Content="Вычислить" Click="Calculate_Click"/>
    <TextBlock x:Name="ResultText"/>
    </StackPanel>
</Window>

